      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[0].questionText
      value: "\u0110\u1ED1i t\u01B0\u1EE3ng nghi\xEAn c\u1EE9u c\u1EE7a h\xF3a h\u1ECDc
        l\xE0 g\xEC?"
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[1].questionText
      value: "C\xC2U 2: KHI L\xC0M TH\u1EF0C H\xC0NH H\xD3A H\u1ECCC, H\xC0NH \u0110\u1ED8NG
        N\xC0O SAU \u0110\xC2Y L\xC0 KH\xD4NG AN TO\xC0N?"
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[2].questionText
      value: "C\xC2U 3: D\u1EE4NG C\u1EE4 N\xC0O SAU \u0110\xC2Y D\xD9NG \u0110\u1EC2
        \u0110O TH\u1EC2 T\xCDCH CH\u1EA4T L\u1ECENG CH\xCDNH X\xC1C NH\u1EA4T?"
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].questionText
      value: "C\xC2U 4: KHI V\xD4 T\xCCNH B\u1ECA H\xD3A CH\u1EA4T D\xCDNH V\xC0O
        TAY, B\u01AF\u1EDAC S\u01A0 C\u1EE8U \u0110\u1EA6U TI\xCAN C\u1EA6N L\xC0M
        L\xC0 G\xCC?"
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].questionText
      value: "C\xC2U 5: L\u0128NH V\u1EF0C N\xC0O SAU \u0110\xC2Y KH\xD4NG PH\u1EA2I
        L\xC0 \u1EE8NG D\u1EE4NG C\u1EE6A H\xD3A H\u1ECCC?"
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[0].correctAnswerIndex
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
