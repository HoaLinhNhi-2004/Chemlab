      propertyPath: questions.Array.data[2].correctAnswerIndex
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].answers.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].correctAnswerIndex
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].answers.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].correctAnswerIndex
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[0].answers.Array.data[0]
      value: "C\xE1c h\u1EA1t c\u01A1 b\u1EA3n trong nh\xE2n nguy\xEAn t\u1EED v\xE0
        c\xE1c h\xE0nh tinh."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[0].answers.Array.data[1]
      value: "Ch\u1EA5t, s\u1EF1 bi\u1EBFn \u0111\u1ED5i c\u1EE7a ch\u1EA5t v\xE0
        n\u0103ng l\u01B0\u1EE3ng \u0111i k\xE8m c\xE1c qu\xE1 tr\xECnh \u0111\xF3."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[0].answers.Array.data[2]
      value: "C\xE1c sinh v\u1EADt s\u1ED1ng v\xE0 s\u1EF1 ph\xE1t tri\u1EC3n c\u1EE7a
        ch\xFAng trong t\u1EF1 nhi\xEAn."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[1].answers.Array.data[0]
      value: "A. \u0110eo k\xEDnh b\u1EA3o h\u1ED9 v\xE0 g\u0103ng tay c\u1EA9n th\u1EADn."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[1].answers.Array.data[1]
      value: "B. N\u1EBFm th\u1EED ho\u1EB7c ng\u1EEDi tr\u1EF1c ti\u1EBFp h\xF3a
        ch\u1EA5t."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[1].answers.Array.data[2]
      value: "C. R\u1EEDa tay s\u1EA1ch s\u1EBD b\u1EB1ng x\xE0 ph\xF2ng sau khi
        th\u1EF1c h\xE0nh."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[2].answers.Array.data[0]
      value: "A. \u1ED0ng \u0111ong (b\xECnh chia \u0111\u1ED9)."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[2].answers.Array.data[1]
      value: "B. C\u1ED1c th\u1EE7y tinh c\xF3 m\u1ECF."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[2].answers.Array.data[2]
      value: "C. \u1ED0ng nghi\u1EC7m th\u1EE7y tinh."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].answers.Array.data[0]
      value: "A. L\u1EA5y kh\u0103n gi\u1EA5y kh\xF4 lau th\u1EADt m\u1EA1nh cho
        s\u1EA1ch."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].answers.Array.data[1]
      value: "B. B\xF4i ngay kem \u0111\xE1nh r\u0103ng l\xEAn v\xF9ng da b\u1ECB
        d\xEDnh."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[3].answers.Array.data[2]
      value: "C. R\u1EEDa ngay l\u1EADp t\u1EE9c d\u01B0\u1EDBi v\xF2i n\u01B0\u1EDBc
        s\u1EA1ch nhi\u1EC1u ph\xFAt."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].answers.Array.data[0]
      value: "A. S\u1EA3n xu\u1EA5t thu\u1ED1c ch\u1EEFa b\u1EC7nh v\xE0 ph\xE2n
        b\xF3n."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].answers.Array.data[1]
      value: "B. Ch\u1EBF t\u1EA1o v\u1EADt li\u1EC7u x\xE2y d\u1EF1ng v\xE0 \u0111\u1ED3
        nh\u1EF1a."
      objectReference: {fileID: 0}
    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[4].answers.Array.data[2]
      value: "C. Nghi\xEAn c\u1EE9u qu\u1EF9 \u0111\u1EA1o bay c\u1EE7a c\xE1c v\xEC
        sao."
      objectReference: {fileID: 0}
    - target: {fileID: 8249845777602967149, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: m_text
      value: "A. C\xE1c h\u1EA1t c\u01A1 b\u1EA3n trong nh\xE2n nguy\xEAn t\u1EED
        v\xE0 c\xE1c h\xE0nh tinh."
