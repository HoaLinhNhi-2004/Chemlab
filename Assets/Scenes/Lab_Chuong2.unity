    - target: {fileID: 8046907598210167310, guid: 1cd287c9f7fe0fb429fa14f39e187480,
        type: 3}
      propertyPath: questions.Array.data[1].questionText
      value: "C\xC2U 2: KHI L\xC0M TH\u1EF0C H\xC0NH H\xD3A H\u1ECCC, H\xC0NH \u0110\u1ED8NG
